model Project {
  id          String   @id @default(uuid())
  name        String
  description String
  phase       Phase    @default(BACKLOG)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  phaseJobs        PhaseJob[]
  ideationMessages IdeationMessage[]
  jobLogs          JobLog[]
  artifacts        Artifact[]
  approvalRequests ApprovalRequest[]

  @@map("projects")
}

model PhaseJob {
  id            String    @id @default(uuid())
  projectId     String    @map("project_id")
  phase         Phase
  status        JobStatus @default(QUEUED)
  blockerReason String?   @map("blocker_reason")
  createdAt     DateTime  @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ideationMessages IdeationMessage[]
  jobLogs          JobLog[]

  @@map("phase_jobs")
}

model IdeationMessage {
  id               String   @id @default(uuid())
  phaseJobId       String   @map("phase_job_id")
  projectId        String   @map("project_id")
  role             String   // "user" | "agent"
  content          String
  citationsJson    String?  @map("citations_json")
  filesWrittenJson String?  @map("files_written_json")
  containerExitCode Int?    @map("container_exit_code")
  createdAt        DateTime @default(now()) @map("created_at")

  phaseJob PhaseJob @relation(fields: [phaseJobId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("ideation_messages")
}

model JobLog {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  jobId     String   @map("job_id")
  phase     Phase
  level     LogLevel
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phaseJob PhaseJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_logs")
}

model Artifact {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  phase     Phase
  filePath  String   @map("file_path")
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("artifacts")
}

